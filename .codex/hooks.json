{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "^Bash$",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-block-no-verify-commit.sh\"",
                        "timeout": 30,
                        "statusMessage": "Blocking no-verify commit"
                    }
                ]
            },
            {
                "matcher": "^(apply_patch|Edit|MultiEdit|Write)$",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-block-rule-change.sh\"",
                        "timeout": 30,
                        "statusMessage": "Blocking rule change"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "^(apply_patch|Edit|MultiEdit|Write)$",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-check-swift.sh\"",
                        "timeout": 300,
                        "statusMessage": "Checking Swift"
                    },
                    {
                        "type": "command",
                        "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-check-feature-list-json.sh\"",
                        "timeout": 120,
                        "statusMessage": "Checking feature_list.json"
                    }
                ]
            }
        ]
    }
}
